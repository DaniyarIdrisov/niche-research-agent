# =========================================================================
# Niche Research Agent — environment configuration
# Copy this file to .env and adjust as needed.
# =========================================================================

# --- Источник данных WB ------------------------------------------------------
# mock — фейковый датасет из data/mock_wb_products.json (по умолчанию)
# live — реальный парсинг через search.wb.ru (серая зона, может перестать работать)
DATA_SOURCE=mock

# --- Ollama (LLM + эмбеддинги) -----------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=qwen2.5:3b-instruct-q4_K_M
OLLAMA_EMBED_MODEL=nomic-embed-text

# Длина контекста и таймауты
OLLAMA_NUM_CTX=4096
OLLAMA_REQUEST_TIMEOUT=120

# --- ChromaDB ---------------------------------------------------------------
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=niche_research_kb

# --- Episodic memory (SQLite) -----------------------------------------------
SQLITE_PATH=./data/episodic.db

# --- RAG --------------------------------------------------------------------
RAG_TOP_K_DENSE=10
RAG_TOP_K_BM25=10
RAG_FINAL_K=5
RAG_DENSE_WEIGHT=0.6
RAG_BM25_WEIGHT=0.4
# Реранкер. На 4 GB VRAM по умолчанию выключен — даёт +10-15% к качеству, но
# требует выгрузки LLM на время вызова.
RAG_USE_RERANKER=false
RAG_RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# --- LangGraph --------------------------------------------------------------
MAX_RETRIES_PER_NODE=2
LANGGRAPH_CHECKPOINT_DB=./data/checkpoints.sqlite

# --- Observability ----------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=./logs/agent.jsonl

# OpenTelemetry → Collector (Jaeger через коллектор)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=niche-research-agent

# Prometheus metrics — приложение поднимает endpoint на этом порту
METRICS_PORT=9464

# Langfuse (self-hosted)
LANGFUSE_HOST=http://localhost:3001
LANGFUSE_PUBLIC_KEY=pk-lf-local
LANGFUSE_SECRET_KEY=sk-lf-local

# --- WB live-режим (только если DATA_SOURCE=live) ---------------------------
WB_SEARCH_URL=https://search.wb.ru/exactmatch/ru/common/v9/search
WB_REQUEST_RATE_PER_SEC=2
WB_REQUEST_TIMEOUT=15
WB_USER_AGENT=Mozilla/5.0 (compatible; NicheResearchAgent/0.1; +https://example.com)

# --- CLI defaults -----------------------------------------------------------
DEFAULT_TOP_N=30
RUNS_DIR=./runs
